# ============================================================
# AI Provider
#
# AI_PROVIDER=openai     → use OpenAI Responses API for text generation
# AI_PROVIDER=anthropic  → use Claude as primary
# Leave empty: auto-detects OpenAI if OPENAI_* tokens exist, otherwise Anthropic.
# ============================================================
AI_PROVIDER=

# ============================================================
# OpenAI API / OAuth
#
# Set OPENAI_OAUTH_ACCESS_TOKEN for OAuth bearer auth, or OPENAI_API_KEY
# for standard API key auth. OAuth token takes priority over API key.
# ============================================================
OPENAI_OAUTH_ACCESS_TOKEN=
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: split text and image providers
# e.g. use a ChatGPT OAuth gateway for text, OpenAI Platform API for images
OPENAI_TEXT_BASE_URL=
OPENAI_TEXT_API_KEY=
OPENAI_TEXT_OAUTH_ACCESS_TOKEN=
OPENAI_TEXT_REQUEST_FORMAT=
OPENAI_IMAGE_BASE_URL=
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_OAUTH_ACCESS_TOKEN=

# Optional: protect agent endpoints with a shared token.
# If set, /api/agent/run and /api/write-json require Bearer or x-pipeline-token header.
PIPELINE_AGENT_TOKEN=

# ============================================================
# Anthropic Claude (fallback)
# Get yours at: https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ============================================================
# Brave Search API (required for research step)
# Get yours at: https://brave.com/search/api/
# ============================================================
BRAVE_SEARCH_API_KEY=

# ============================================================
# Facebook Graph API — Auto-publish to a Facebook Page
#
# HOW TO GET THESE:
#
# 1. FB_PAGE_ID:
#    Go to your Page → About → Page ID (numeric)
#
# 2. FB_PAGE_ACCESS_TOKEN (never-expiring):
#    Step 1: Create a Meta App at https://developers.facebook.com/apps/
#    Step 2: Go to Graph API Explorer → select your app
#            Add permissions: pages_show_list, pages_read_engagement, pages_manage_posts
#            Generate Access Token (short-lived user token)
#    Step 3: Exchange for long-lived token:
#            GET https://graph.facebook.com/oauth/access_token
#              ?grant_type=fb_exchange_token&client_id={APP_ID}
#              &client_secret={APP_SECRET}&fb_exchange_token={SHORT_LIVED_TOKEN}
#    Step 4: Get never-expiring Page Token:
#            GET https://graph.facebook.com/me/accounts?access_token={LONG_LIVED_TOKEN}
#            Find your page → copy "access_token"
#    Step 5: Verify at https://developers.facebook.com/tools/debug/accesstoken/
#            "Expires" should show "Never"
#
# IMPORTANT:
#   - Token is revoked if you change your Facebook password
#   - Token is revoked if you remove app permissions
#   - For unverified Pages: use app Development Mode
#   - Production (other Pages): requires Business Verification + App Review
# ============================================================
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# If set, /api/fb-publish can use the server-side FB_PAGE_ACCESS_TOKEN
# when the request includes a matching x-admin-secret header.
# If empty, the route only accepts tokens passed by the client.
FB_PUBLISH_ADMIN_SECRET=
